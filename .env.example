# Solana Blink Wrapper — Environment Variables
# Copy to .env.local for local development: cp .env.example .env.local

# Solana JSON-RPC endpoint (defaults to Devnet in development)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Donation wallet public key — required in production, uses a dev fallback otherwise
SOLANA_DONATION_WALLET=

# Blockchain ID for action headers (e.g. solana:devnet, solana:mainnet)
# See @solana/actions BLOCKCHAIN_IDS for supported values
SOLANA_BLOCKCHAIN_ID=solana:devnet
